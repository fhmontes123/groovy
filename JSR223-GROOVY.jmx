        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">def categorias = [&quot;electronicos&quot;, &quot;deporte&quot;, &quot;ropa de hombre&quot;, &quot;ropa de mujer&quot;, &quot;juguetes&quot;]

def id = (Math.random() * 999 + 1) as int
vars.put(&quot;randomId&quot;, id.toString())
def title = &quot;Titulo ${(Math.random() * 9999 + 1) as int}&quot;
vars.put(&quot;randomTitle&quot;, title)
def price = Math.round((Math.random() * 400 + 100) * 100) / 100		// Valor entre 100 - 500
vars.put(&quot;randomPrice&quot;, price.toString())
def description = &quot;Descripcion ${(Math.random() * 999 + 1) as int}&quot;
vars.put(&quot;randomDescription&quot;, description)
def category = categorias[(Math.random() * categorias.size()) as int]
vars.put(&quot;randomCategory&quot;, category)</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223PreProcessor>
